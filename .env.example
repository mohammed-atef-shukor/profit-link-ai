# Firebase (required — copy from Firebase Console → Project settings → Web app)

# Also set these in Netlify: Site settings → Environment variables (or `netlify env:import .env`)

VITE_FIREBASE_API_KEY=

VITE_FIREBASE_AUTH_DOMAIN=

VITE_FIREBASE_PROJECT_ID=

VITE_FIREBASE_STORAGE_BUCKET=

VITE_FIREBASE_MESSAGING_SENDER_ID=

VITE_FIREBASE_APP_ID=

